{
  "manifest_version": 3,
  "name": "DriftX",
  "version": "1.0.0",
  "description": "A demo-safe AI reliability layer that simulates drift and self-healing on chatbot interfaces.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "DriftX",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
